{
  "name": "llmquest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LLM-TextQuest MVP backend scaffold",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
